#
# .env.example – copy to .env and fill in the values.
# NEVER commit .env to version control.

# ── Onshape OAuth credentials ─────────────────────────────────────────────
# Obtain from https://dev-portal.onshape.com/
ONSHAPE_CLIENT_ID=your-client-id-here
ONSHAPE_CLIENT_SECRET=your-client-secret-here

# ── App Server ────────────────────────────────────────────────────────────
# Public HTTPS URL of the App Server (used to build the OAuth redirect URI).
APP_HOST=https://your-app-server.example.com

# ── Session security ──────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-to-a-random-64-hex-char-string

# Set to true in production (HTTPS deployments).
# Set to false for local HTTP development.
SESSION_HTTPS_ONLY=true

# Cookie SameSite policy.  "none" is required for Onshape iframe embedding
# (cross-site context); use "lax" or "strict" for same-site deployments.
SESSION_COOKIE_SAMESITE=none

# ── Worker authentication ─────────────────────────────────────────────────
# Token that workers must supply in the X-Worker-Token header.
# Required unless DEV_MODE=true.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
WORKER_TOKEN=change-me-to-a-random-token

# ── Development mode ──────────────────────────────────────────────────────
# Set to true to disable WORKER_TOKEN requirement and STEP export during local
# development.  NEVER set to true in production.
DEV_MODE=false

# ── Frontend directory ────────────────────────────────────────────────────
# Path to the frontend/ directory.  Required for local non-Docker development.
# Example: FRONTEND_DIR=../frontend
# (In Docker, ./frontend is mounted at /app/frontend automatically.)
# FRONTEND_DIR=../frontend

# ── Job database ──────────────────────────────────────────────────────────
# Path to the SQLite database file used by the job queue.
JOB_DB_PATH=/tmp/g4occt_jobs.db

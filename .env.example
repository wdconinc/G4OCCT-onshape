#
# .env.example – copy to .env and fill in the values.
# NEVER commit .env to version control.

# ── Onshape OAuth credentials ─────────────────────────────────────────────
# Obtain from https://dev-portal.onshape.com/
ONSHAPE_CLIENT_ID=your-client-id-here
ONSHAPE_CLIENT_SECRET=your-client-secret-here

# ── App Server ────────────────────────────────────────────────────────────
# Public HTTPS URL of the App Server (used to build the OAuth redirect URI).
APP_HOST=https://your-app-server.example.com

# ── Session security ──────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-to-a-random-64-hex-char-string

# ── Worker authentication ─────────────────────────────────────────────────
# Token that workers must supply in the X-Worker-Token header.
# Leave empty to disable token enforcement (development only).
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
WORKER_TOKEN=change-me-to-a-random-token

# ── Job database ──────────────────────────────────────────────────────────
# Path to the SQLite database file used by the job queue.
JOB_DB_PATH=/tmp/g4occt_jobs.db
